{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src/main", "src/preload", "src/shared"],
  "exclude": ["src/**/*.test.ts", "src/renderer"]
}
